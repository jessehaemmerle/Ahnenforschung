DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ahnenforschung?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-at-least-32-random-bytes"

# Google OAuth, required for production login.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional magic-link email login.
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="Ahnenforschung <no-reply@example.com>"

# Optional outbound invitation emails. If empty, invitation links are still stored and shown in the API response.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Ahnenforschung <no-reply@example.com>"

UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB="8"
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX="120"
